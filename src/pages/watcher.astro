---
// watcher.astro - Philapps Watcher Timeline
// Ce fichier est généré pour être intégré dans le projet Astro "Philapps Garage"

const response = await fetch('https://coolifybackuppar.s3.fr-par.scw.cloud/rss-public/tech_digest_rss.xml');
const xmlData = await response.text();

const items = [...xmlData.matchAll(/<item>([\s\S]*?)<\/item>/g)].map(match => {
  const content = match[1];
  return {
    title: content.match(/<title><!\[CDATA\[(.*?)\]\]><\/title>/)?.[1] || "Sans titre",
    link: content.match(/<link>(.*?)<\/link>/)?.[1],
    pubDate: content.match(/<pubDate>(.*?)<\/pubDate>/)?.[1],
    description: content.match(/<description><!\[CDATA\[(.*?)\]\]><\/description>/)?.[1] || "",
  };
});

const formatDate = (dateStr) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });
};
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Watcher - Philapps Veille</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 font-sans antialiased text-slate-900">
    <nav class="bg-white border-b border-slate-200 py-4 mb-12">
        <div class="max-w-4xl mx-auto px-6 flex justify-between items-center">
            <a href="/" class="font-bold text-xl tracking-tight text-blue-600">philapps<span class="text-slate-400">.com</span></a>
            <a href="https://coolifybackuppar.s3.fr-par.scw.cloud/rss-public/tech_digest_rss.xml" class="text-slate-500 hover:text-orange-500 transition-colors">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.797 1.456-3.251 3.252-3.251 1.795.001 3.251 1.454 3.251 3.251zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.71-7.118-15.758-15.839-15.82zm0-8.18v4.831c10.555.062 19.121 8.618 19.182 19.171h4.818c-.061-13.208-10.776-23.931-23.999-24.002z"/></svg>
            </a>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto px-6 pb-24">
        <header class="mb-16">
            <h1 class="text-5xl font-extrabold text-slate-900 mb-6 tracking-tight">The Watcher</h1>
            <p class="text-xl text-slate-600 max-w-2xl leading-relaxed">
                Flux de veille technologique automatisé. <br/>
                Propulsé par <span class="text-blue-600 font-semibold">Claw</span>, mon assistant sur VPS.
            </p>
        </header>

        <div class="relative">
            <!-- Vertical Line -->
            <div class="absolute left-[11px] top-2 bottom-0 w-0.5 bg-slate-200"></div>

            <div class="space-y-12">
                {items.map((item) => (
                    <article class="relative pl-10 group">
                        <!-- Dot -->
                        <div class="absolute left-0 top-2 w-6 h-6 bg-white border-2 border-blue-500 rounded-full z-10 group-hover:bg-blue-500 transition-colors duration-200 shadow-sm"></div>
                        
                        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition-all duration-300 transform group-hover:-translate-y-1">
                            <time class="inline-block px-3 py-1 bg-slate-100 text-slate-500 rounded-full text-xs font-bold uppercase tracking-wider mb-4">
                                {formatDate(item.pubDate)}
                            </time>
                            
                            <h2 class="text-2xl font-bold text-slate-900 mb-4 group-hover:text-blue-600 transition-colors leading-tight">
                                <a href={item.link} target="_blank" rel="noopener noreferrer">
                                    {item.title}
                                </a>
                            </h2>

                            <p class="text-slate-600 mb-6 leading-relaxed">
                                {item.description}
                            </p>
                            
                            <div class="flex items-center">
                                <a href={item.link} target="_blank" rel="noopener noreferrer" 
                                   class="text-blue-600 font-semibold flex items-center gap-2 hover:gap-3 transition-all">
                                    Consulter la source
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                                </a>
                            </div>
                        </div>
                    </article>
                ))}
            </div>
        </div>

        <footer class="mt-20 pt-12 border-t border-slate-200 text-center text-slate-400 text-sm">
            &copy; {new Date().getFullYear()} Philapps Garage. Build with Astro & 🦞 Claw.
        </footer>
    </main>
</body>
</html>
