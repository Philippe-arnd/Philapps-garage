---
import '../styles/global.css';
// watcher.astro - Philapps Watcher Timeline (Dynamic Client-Side Version)
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>PhilApps.com — The Watcher</title>
</head>
<body class="bg-dos-bg">
  <!-- Scanline grid overlay -->
  <div class="fixed inset-0 pointer-events-none opacity-10 bg-[linear-gradient(to_right,#00ff00_1px,transparent_1px),linear-gradient(to_bottom,#00ff00_1px,transparent_1px)] bg-[size:4rem_4rem] z-[-1] grid-background"></div>

  <!-- NAV -->
  <header class="fixed w-full top-0 z-50 bg-dos-bg/80 backdrop-blur-xl border-b border-white/5 py-6">
    <nav class="container mx-auto px-6 flex justify-between items-center">
      <a href="/" class="flex items-center gap-2 select-none group cursor-pointer">
        <span class="text-2xl text-white oxanium-title font-bold tracking-[0.2em] group-hover:tracking-[0.3em] transition-all duration-500">PHILAPPS_</span>
      </a>
      <ul class="flex items-center gap-4 md:gap-10 text-[10px] font-pixel tracking-[0.2em] md:tracking-[0.3em] text-white/40 uppercase">
        <li class="hidden sm:block"><a href="/#about" class="hover:text-white transition-colors">About</a></li>
        <li class="hidden sm:block"><a href="/#portfolio" class="hover:text-white transition-colors">Portfolio</a></li>
        <li>
          <a href="https://status.philapps.com/status/public" target="_blank" class="flex items-center gap-2 md:gap-3 text-dos-green border border-dos-green/20 px-3 md:px-4 py-1.5 md:py-2 hover:bg-dos-green hover:text-black transition-all">
            <span class="relative flex h-1.5 w-1.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-dos-green opacity-75"></span>
              <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-dos-green"></span>
            </span>
            <span class="text-[8px] md:text-[10px]">Status</span>
          </a>
        </li>
      </ul>
    </nav>
  </header>

  <main class="max-w-5xl mx-auto px-6 pb-32 pt-28">

    <!-- HERO SECTION -->
    <section class="py-20 border-b border-white/5 mb-20">
      <div class="max-w-5xl mx-auto p-12 bg-white hero-card shadow-2xl">
        <div class="flex items-center gap-5 mb-10">
          <div class="eye-wrapper" aria-hidden="true">
            <svg class="eye-svg" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="50" cy="50" r="46" fill="white" stroke="black" stroke-width="7"/>
              <g class="pupil-group">
                <circle cx="50" cy="50" r="26" fill="black"/>
                <circle cx="41" cy="40" r="10" fill="white"/>
              </g>
            </svg>
          </div>
          <h1 class="text-4xl md:text-6xl oxanium-title text-black/90 normal-case leading-none">
            The Watcher
          </h1>
        </div>

        <div class="grid md:grid-cols-3 gap-12 items-start">
          <div class="flex flex-col items-center gap-6">
            <div id="status-card" class="w-full bg-black/[0.03] border border-black/10 p-8 flex flex-col gap-4 font-sans text-[10px] text-black/40 overflow-hidden">
              <div class="flex justify-between">
                <span id="status-text">Initializing...</span>
                <span id="status-live-tag" class="hidden text-dos-green font-bold animate-pulse">[live]</span>
              </div>
              <div class="w-full h-1 bg-black/5 relative overflow-hidden">
                <div id="progress-bar" class="absolute inset-y-0 left-0 bg-black/40 w-0 transition-all duration-500"></div>
              </div>
              <div id="status-logs" class="flex flex-col gap-1 opacity-50">
                <span>&gt; connecting...</span>
              </div>
            </div>
            <p id="stats-days" class="text-[10px] font-pixel text-black/30 uppercase tracking-widest">--- days indexed</p>
          </div>

          <div class="md:col-span-2 text-lg md:text-xl font-sans leading-relaxed text-black/60 space-y-6">
            <p>
              An automated tech intelligence feed, running 24/7. Every article here was
              discovered, parsed, and surfaced by <a href="https://github.com/openclaw/openclaw" target="_blank" rel="noopener noreferrer" class="text-black border-b border-black/20 hover:border-black transition-colors">🦞 OpenClaw</a> —
              the personal AI-powered research crawler.
            </p>
            <p>
              No editorial bias. No algorithm. Just raw signal from the web, distilled daily.
              <strong class="text-black font-medium italic">Noise in. Signal out.</strong>
            </p>
            <div class="pt-4 grid grid-cols-3 gap-8">
              <div>
                <span id="stats-articles-count" class="block text-black font-bold text-2xl tracking-tighter">---</span>
                <span class="text-[10px] font-pixel text-black/30 uppercase tracking-widest">Articles</span>
              </div>
              <div>
                <span id="stats-days-count" class="block text-black font-bold text-2xl tracking-tighter">---</span>
                <span class="text-[10px] font-pixel text-black/30 uppercase tracking-widest">Days</span>
              </div>
              <div>
                <span class="block text-black font-bold text-2xl tracking-tighter">24/7</span>
                <span class="text-[10px] font-pixel text-black/30 uppercase tracking-widest">Uptime</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TIMELINE SECTION -->
    <section>
      <h2 class="text-xs font-pixel text-white/20 uppercase tracking-[0.3em] mb-12">// Timeline</h2>

      <div class="relative timeline-container">
        <!-- Vertical line -->
        <div class="absolute left-[11px] top-0 bottom-0 w-px bg-white/5"></div>

        <div id="timeline-root" class="space-y-0">
          <!-- Dynamically injected -->
          <div id="initial-loader" class="py-20 text-center">
             <div class="inline-block animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-dos-green mb-4"></div>
             <p class="text-xs font-pixel text-white/20 uppercase tracking-widest">Fetching Signal...</p>
          </div>
        </div>

        <!-- Load More Button -->
        <div id="load-more-container" class="hidden pt-12 text-center relative z-20">
          <button id="load-more-btn" class="px-8 py-4 bg-white text-black font-pixel text-[10px] uppercase tracking-[0.3em] hover:bg-dos-green transition-all shadow-xl">
            Load Older Signals
          </button>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="mt-24 pt-12 border-t border-white/5 flex justify-between items-center text-white/15 text-xs font-sans">
      <span>&copy; {new Date().getFullYear()} Philapps Garage</span>
      <a href="https://github.com/openclaw/openclaw" target="_blank" rel="noopener noreferrer" class="font-pixel uppercase tracking-widest hover:text-white/40 transition-colors">Powered by 🦞 OpenClaw</a>
    </footer>
  </main>

  <script>
    const RSS_URL = 'https://coolifybackuppar.s3.fr-par.scw.cloud/rss-public/tech_digest_rss.xml';
    const INITIAL_LIMIT = 30;
    
    let allItems = [];
    let displayedCount = 0;

    const timelineRoot = document.getElementById('timeline-root');
    const loadMoreBtn = document.getElementById('load-more-btn');
    const loadMoreContainer = document.getElementById('load-more-container');
    const statsArticles = document.getElementById('stats-articles-count');
    const statsDaysCount = document.getElementById('stats-days-count');
    const statsDaysLabel = document.getElementById('stats-days');
    const progressBar = document.getElementById('progress-bar');
    const statusText = document.getElementById('status-text');
    const statusLogs = document.getElementById('status-logs');
    const liveTag = document.getElementById('status-live-tag');

    const addLog = (msg, colorClass = '') => {
      const span = document.createElement('span');
      if (colorClass) span.className = colorClass;
      span.innerText = `> ${msg}`;
      statusLogs.appendChild(span);
    };

    const ICONS = {
      AI: `<svg viewBox="0 0 10 10" class="w-3 h-3" fill="currentColor"><path d="M3 2h4v1h1v4h-1v1h-4v-1h-1v-4h1v-1zm1 2h2v2h-2v-2z"/></svg>`,
      SEC: `<svg viewBox="0 0 10 10" class="w-3 h-3" fill="currentColor"><path d="M3 4h4v5h-4v-5zm1-3h2v3h-2v-3z M4 2h2v1h-2v-1z"/><rect x="4" y="6" width="2" height="1"/></svg>`,
      SYS: `<svg viewBox="0 0 10 10" class="w-3 h-3" fill="currentColor"><path d="M2 2h6v6h-6v-6zm1 1v4h4v-4h-4z"/><rect x="0" y="4" width="2" height="2"/><rect x="8" y="4" width="2" height="2"/><rect x="4" y="0" width="2" height="2"/><rect x="4" y="8" width="2" height="2"/></svg>`,
      DEV: `<svg viewBox="0 0 10 10" class="w-3 h-3" fill="currentColor"><path d="M3 2l-2 3 2 3h1l-2-3 2-3h-1zm4 0l2 3-2 3h-1l2-3-2-3h1z"/></svg>`,
      MISC: `<svg viewBox="0 0 10 10" class="w-3 h-3" fill="currentColor"><path d="M2 1h4l3 3v5h-7v-8zm1 1v6h5v-4h-2v-2h-3z"/></svg>`
    };

    function getCategory(title, desc) {
      const text = (title + ' ' + desc).toLowerCase();
      if (text.includes('ai ') || text.includes('ai-') || text.includes('llm') || text.includes('agent') || text.includes('claude') || text.includes('gpt') || text.includes('openai') || text.includes('neural')) return 'AI';
      if (text.includes('security') || text.includes('vulnerability') || text.includes('exploit') || text.includes('hack') || text.includes('privacy') || text.includes('auth') || text.includes('cookie') || text.includes('attack')) return 'SEC';
      if (text.includes('hardware') || text.includes('gpu') || text.includes('system') || text.includes('low-level') || text.includes('stm32') || text.includes('quantum') || text.includes('performance') || text.includes('rust ') || text.includes('zig ')) return 'SYS';
      if (text.includes('dev') || text.includes('code') || text.includes('language') || text.includes('typescript') || text.includes('react') || text.includes('javascript') || text.includes('mcp')) return 'DEV';
      return 'MISC';
    }

    const formatDate = (date) => date.toLocaleDateString("en-GB", { weekday: "long", day: "2-digit", month: "long", year: "numeric" });
    const formatMonth = (date) => date.toLocaleDateString("en-GB", { month: "long", year: "numeric" });

    async function init() {
      try {
        progressBar.style.width = '30%';
        addLog('fetch_rss.sh...');
        
        const res = await fetch(RSS_URL);
        if (!res.ok) throw new Error('Network error');
        
        progressBar.style.width = '60%';
        addLog('parse_digest.bin...', 'text-dos-green');
        
        const xmlText = await res.text();
        const parser = new DOMParser();
        const xmlDoc = parser.parseFromString(xmlText, "text/xml");
        const entries = xmlDoc.querySelectorAll("item");
        
        allItems = Array.from(entries).map(item => ({
          title: item.querySelector("title")?.textContent || "Untitled",
          link: item.querySelector("link")?.textContent || "#",
          pubDate: item.querySelector("pubDate")?.textContent || "",
          description: item.querySelector("description")?.textContent || ""
        }));

        progressBar.style.width = '100%';
        statusText.innerText = 'Signal ready';
        liveTag.classList.remove('hidden');
        addLog('digest_ready!', 'text-dos-green font-bold');

        // Update Stats
        const daysSet = new Set(allItems.map(i => new Date(i.pubDate).toISOString().split('T')[0]));
        statsArticles.innerText = allItems.length;
        statsDaysCount.innerText = daysSet.size;
        statsDaysLabel.innerText = `${daysSet.size} days indexed`;

        timelineRoot.innerHTML = '';
        renderNextBatch();

        if (allItems.length > INITIAL_LIMIT) {
          loadMoreContainer.classList.remove('hidden');
        }

      } catch (err) {
        console.error(err);
        timelineRoot.innerHTML = `<div class="py-20 text-center text-red-500 font-pixel uppercase tracking-widest">Error: Lost Signal</div>`;
      }
    }

    function renderNextBatch() {
      const batch = allItems.slice(displayedCount, displayedCount + INITIAL_LIMIT);
      if (batch.length === 0) return;

      // Group batch by month/day
      const groups = {};
      batch.forEach(item => {
        const d = new Date(item.pubDate);
        const mKey = d.getFullYear() + '-' + (d.getMonth() + 1);
        const dKey = d.toISOString().split('T')[0];
        
        if (!groups[mKey]) groups[mKey] = {};
        if (!groups[mKey][dKey]) groups[mKey][dKey] = [];
        groups[mKey][dKey].push(item);
      });

      Object.entries(groups).forEach(([mKey, days]) => {
        // Check if month header already exists
        let monthEl = document.querySelector(`[data-month="${mKey}"]`);
        if (!monthEl) {
          const d = new Date(mKey + '-1');
          monthEl = document.createElement('div');
          monthEl.setAttribute('data-month', mKey);
          monthEl.className = 'month-group mb-4';
          monthEl.innerHTML = `
            <div class="month-separator pl-10 relative mb-8 reveal-item visible">
              <div class="absolute left-0 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center z-10">
                <div class="w-3 h-px bg-dos-green/60"></div>
              </div>
              <div class="flex items-center gap-4">
                <span class="text-xs font-pixel text-dos-green/60 uppercase tracking-[0.3em]">${formatMonth(d)}</span>
                <div class="flex-1 h-px bg-white/5"></div>
              </div>
            </div>
            <div class="days-container space-y-10 mb-16"></div>
          `;
          timelineRoot.appendChild(monthEl);
        }

        const daysContainer = monthEl.querySelector('.days-container');
        Object.entries(days).forEach(([dKey, items]) => {
          const d = new Date(dKey + 'T12:00:00Z');
          const dayEl = document.createElement('div');
          dayEl.className = 'timeline-day reveal-item visible pl-10 relative';
          dayEl.innerHTML = `
            <div class="timeline-dot absolute left-0 top-3 w-6 h-6 border border-white/20 rounded-full z-10 bg-dos-bg flex items-center justify-center transition-all duration-500">
              <div class="w-2 h-2 rounded-full bg-white/20 inner-dot transition-all duration-300"></div>
            </div>
            <div class="day-card bg-white rounded-2xl overflow-hidden transition-all duration-500 shadow-sm">
              <div class="px-8 py-5 border-b border-black/5 flex items-center justify-between">
                <time class="oxanium-title text-lg text-black/80 normal-case tracking-tight">${formatDate(d)}</time>
                <span class="text-[10px] font-pixel text-black/20 uppercase tracking-widest">${items.length} ${items.length === 1 ? 'article' : 'articles'}</span>
              </div>
              <div class="divide-y divide-black/5">
                ${items.map((item, i) => {
                  const cat = getCategory(item.title, item.description);
                  return `
                  <article class="article-row px-8 py-6 transition-all duration-300 group/article">
                    <a href="${item.link}" target="_blank" rel="noopener noreferrer" class="block">
                      <div class="flex items-start gap-4">
                        <div class="flex flex-col items-center gap-2 mt-1.5 shrink-0 w-8">
                          <span class="text-[10px] font-pixel text-black/15 uppercase tracking-widest">${String(i + 1).padStart(2, "0")}</span>
                          <div class="text-black/20 group-hover/article:text-black/60 transition-colors duration-200" title="${cat}">
                            ${ICONS[cat]}
                          </div>
                        </div>
                        <div class="flex-1 min-w-0">
                          <h3 class="font-sans text-base font-semibold text-black/80 group-hover/article:text-black leading-snug mb-2 transition-colors duration-200">${item.title}</h3>
                          ${item.description ? `<p class="font-sans text-xs text-black/40 leading-relaxed line-clamp-2">${item.description}</p>` : ''}
                        </div>
                        <div class="shrink-0 mt-1 text-black/15 group-hover/article:text-black/50 transition-colors duration-200">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10"/></svg>
                        </div>
                      </div>
                    </a>
                  </article>
                `}).join('')}
              </div>
            </div>
          `;
          daysContainer.appendChild(dayEl);
        });
      });

      displayedCount += batch.length;
      if (displayedCount >= allItems.length) {
        loadMoreContainer.classList.add('hidden');
      }
    }

    loadMoreBtn.addEventListener('click', () => {
      renderNextBatch();
    });

    init();
  </script>

  <style is:global>
    /* Same styles as before, now global for dynamic elements */
    .hero-card { position: relative; overflow: hidden; }
    .hero-card::before {
      content: ""; position: absolute; inset: 0;
      background: linear-gradient(rgba(18,16,16,0) 50%, rgba(0,0,0,0.015) 50%);
      background-size: 100% 3px; pointer-events: none; z-index: 1;
    }
    .eye-svg { width: 1em; height: 1em; font-size: clamp(2.5rem, 6vw, 3.75rem); display: block; overflow: hidden; }
    @keyframes eyeScan {
      0%, 20%, 100% { transform: translateX(-10px); }
      40% { transform: translateX(0px); }
      60% { transform: translateX(10px); }
      80% { transform: translateX(0px); }
    }
    .eye-svg .pupil-group { animation: eyeScan 3.6s cubic-bezier(0.45, 0, 0.55, 1) infinite; transform-origin: 50px 50px; }
    .day-card { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .timeline-day:hover .day-card {
      transform: translateY(-3px);
      box-shadow: 0 0 0 1px rgba(0, 255, 0, 0.25), 0 8px 32px rgba(0, 255, 0, 0.06), 0 2px 8px rgba(0, 0, 0, 0.4);
    }
    .timeline-day:hover .inner-dot { background-color: #00ff00; box-shadow: 0 0 6px #00ff00; }
    .article-row:hover { background-color: rgba(0, 0, 0, 0.02); }
  </style>
</body>
</html>
