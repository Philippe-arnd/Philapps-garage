---
import '../styles/global.css';

const response = await fetch('https://coolifybackuppar.s3.fr-par.scw.cloud/rss-public/tech_digest_rss.xml');
const xmlData = await response.text();

const items = [...xmlData.matchAll(/<item>([\s\S]*?)<\/item>/g)].map(match => {
  const content = match[1];
  return {
    title: content.match(/<title><!\[CDATA\[(.*?)\]\]><\/title>/)?.[1] || "Untitled",
    link: content.match(/<link>(.*?)<\/link>/)?.[1],
    pubDate: content.match(/<pubDate>(.*?)<\/pubDate>/)?.[1],
    description: content.match(/<description><!\[CDATA\[(.*?)\]\]><\/description>/)?.[1] || "",
  };
});

const getDayKey = (dateStr: string) => {
  const d = new Date(dateStr);
  return isNaN(d.getTime()) ? "unknown" : d.toISOString().split("T")[0];
};

const getMonthKey = (dayKey: string) => dayKey === "unknown" ? "unknown" : dayKey.slice(0, 7);

const formatDayLabel = (dayKey: string) => {
  if (dayKey === "unknown") return "Unknown Date";
  const d = new Date(dayKey + "T12:00:00Z");
  return d.toLocaleDateString("en-GB", { weekday: "long", day: "2-digit", month: "long", year: "numeric" });
};

const formatMonthLabel = (monthKey: string) => {
  if (monthKey === "unknown") return "Unknown";
  const [year, month] = monthKey.split("-");
  const d = new Date(parseInt(year), parseInt(month) - 1, 1);
  return d.toLocaleDateString("en-GB", { month: "long", year: "numeric" });
};

// Group by day
const grouped = new Map<string, typeof items>();
for (const item of items) {
  const key = getDayKey(item.pubDate ?? "");
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(item);
}
const days = [...grouped.entries()];

// Group days by month
const byMonth = new Map<string, Array<[string, typeof items]>>();
for (const [dayKey, dayItems] of days) {
  const mk = getMonthKey(dayKey);
  if (!byMonth.has(mk)) byMonth.set(mk, []);
  byMonth.get(mk)!.push([dayKey, dayItems]);
}
const months = [...byMonth.entries()];
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>PhilApps.com — The Watcher</title>
</head>
<body>
  <!-- Scanline grid overlay -->
  <div class="fixed inset-0 pointer-events-none opacity-10 bg-[linear-gradient(to_right,#00ff00_1px,transparent_1px),linear-gradient(to_bottom,#00ff00_1px,transparent_1px)] bg-[size:4rem_4rem] z-[-1] grid-background"></div>

  <!-- NAV — same as index.astro Header -->
  <header class="fixed w-full top-0 z-50 bg-dos-bg/80 backdrop-blur-xl border-b border-white/5 py-6">
    <nav class="container mx-auto px-6 flex justify-between items-center">
      <a href="/" class="flex items-center gap-2 select-none group cursor-pointer">
        <span class="text-2xl text-white oxanium-title font-bold tracking-[0.2em] group-hover:tracking-[0.3em] transition-all duration-500">PHILAPPS_</span>
      </a>
      <ul class="flex items-center gap-4 md:gap-10 text-[10px] font-pixel tracking-[0.2em] md:tracking-[0.3em] text-white/40 uppercase">
        <li class="hidden sm:block"><a href="/#about" class="hover:text-white transition-colors">About</a></li>
        <li class="hidden sm:block"><a href="/#portfolio" class="hover:text-white transition-colors">Portfolio</a></li>
        <li>
          <a href="https://status.philapps.com/status/public" target="_blank" class="flex items-center gap-2 md:gap-3 text-dos-green border border-dos-green/20 px-3 md:px-4 py-1.5 md:py-2 hover:bg-dos-green hover:text-black transition-all">
            <span class="relative flex h-1.5 w-1.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-dos-green opacity-75"></span>
              <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-dos-green"></span>
            </span>
            <span class="text-[8px] md:text-[10px]">Status</span>
          </a>
        </li>
      </ul>
    </nav>
  </header>

  <main class="max-w-5xl mx-auto px-6 pb-32 pt-28">

    <!-- HERO SECTION -->
    <section class="py-20 border-b border-white/5 mb-20">
      <div class="max-w-5xl mx-auto p-12 bg-white hero-card">

        <!-- Title with animated eye -->
        <div class="flex items-center gap-5 mb-10">
          <!-- Animated eye SVG -->
          <div class="eye-wrapper" aria-hidden="true">
            <svg class="eye-svg" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Outer ring -->
              <circle cx="50" cy="50" r="46" fill="white" stroke="black" stroke-width="7"/>
              <!-- Pupil group — animates left/right -->
              <g class="pupil-group">
                <!-- Iris / pupil -->
                <circle cx="50" cy="50" r="26" fill="black"/>
                <!-- Glint -->
                <circle cx="41" cy="40" r="10" fill="white"/>
              </g>
            </svg>
          </div>
          <h1 class="text-4xl md:text-6xl oxanium-title text-black/90 normal-case leading-none">
            The Watcher
          </h1>
        </div>

        <div class="grid md:grid-cols-3 gap-12 items-start">
          <div class="flex flex-col items-center gap-6">
            <div class="w-full bg-black/[0.03] border border-black/10 p-8 flex flex-col gap-4 font-sans text-[10px] text-black/40 overflow-hidden">
              <div class="flex justify-between">
                <span>Scanning sources...</span>
                <span>[live]</span>
              </div>
              <div class="w-full h-1 bg-black/5 relative overflow-hidden">
                <div class="absolute inset-y-0 left-0 bg-black/40" style="animation: scanProgress 3s ease-in-out infinite;"></div>
              </div>
              <div class="flex flex-col gap-1 opacity-50">
                <span>&gt; fetch_rss.sh</span>
                <span>&gt; parse_digest.bin</span>
                <span class="text-dos-green font-bold">&gt; digest_ready!</span>
              </div>
            </div>
            <p class="text-[10px] font-pixel text-black/30 uppercase tracking-widest">{days.length} days indexed</p>
          </div>

          <div class="md:col-span-2 text-lg md:text-xl font-sans leading-relaxed text-black/60 space-y-6">
            <p>
              An automated tech intelligence feed, running 24/7. Every article here was
              discovered, parsed, and surfaced by <a href="https://github.com/openclaw/openclaw" target="_blank" rel="noopener noreferrer" class="text-black border-b border-black/20 hover:border-black transition-colors">🦞 OpenClaw</a> —
              the personal AI-powered research crawler.
            </p>
            <p>
              No editorial bias. No algorithm. Just raw signal from the web, distilled daily.
              <strong class="text-black font-medium italic">Noise in. Signal out.</strong>
            </p>
            <div class="pt-4 grid grid-cols-3 gap-8">
              <div>
                <span class="block text-black font-bold text-2xl tracking-tighter">{items.length}</span>
                <span class="text-[10px] font-pixel text-black/30 uppercase tracking-widest">Articles</span>
              </div>
              <div>
                <span class="block text-black font-bold text-2xl tracking-tighter">{days.length}</span>
                <span class="text-[10px] font-pixel text-black/30 uppercase tracking-widest">Days</span>
              </div>
              <div>
                <span class="block text-black font-bold text-2xl tracking-tighter">24/7</span>
                <span class="text-[10px] font-pixel text-black/30 uppercase tracking-widest">Uptime</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TIMELINE SECTION -->
    <section>
      <h2 class="text-xs font-pixel text-white/20 uppercase tracking-[0.3em] mb-12">// Timeline</h2>

      <div class="relative timeline-container">
        <!-- Vertical line -->
        <div class="absolute left-[11px] top-0 bottom-0 w-px bg-white/5"></div>

        <div id="timeline" class="space-y-0">
          {months.map(([monthKey, monthDays]) => (
            <div class="month-group mb-4">

              <!-- Month separator -->
              <div class="month-separator pl-10 relative mb-8 reveal-item">
                <div class="absolute left-0 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center z-10">
                  <div class="w-3 h-px bg-dos-green/60"></div>
                </div>
                <div class="flex items-center gap-4">
                  <span class="text-xs font-pixel text-dos-green/60 uppercase tracking-[0.3em]">
                    {formatMonthLabel(monthKey)}
                  </span>
                  <div class="flex-1 h-px bg-white/5"></div>
                  <span class="text-[10px] font-pixel text-white/15 uppercase tracking-widest">
                    {monthDays.length} {monthDays.length === 1 ? "day" : "days"}
                  </span>
                </div>
              </div>

              <!-- Days in this month -->
              <div class="space-y-10 mb-16">
                {monthDays.map(([dayKey, dayItems]) => (
                  <div class="timeline-day reveal-item pl-10 relative">
                    <!-- Dot -->
                    <div class="timeline-dot absolute left-0 top-3 w-6 h-6 border border-white/20 rounded-full z-10 bg-dos-bg flex items-center justify-center transition-all duration-500">
                      <div class="w-2 h-2 rounded-full bg-white/20 inner-dot transition-all duration-300"></div>
                    </div>

                    <!-- Day card -->
                    <div class="day-card bg-white rounded-2xl overflow-hidden transition-all duration-500">
                      <!-- Day header -->
                      <div class="px-8 py-5 border-b border-black/5 flex items-center justify-between">
                        <time class="oxanium-title text-lg text-black/80 normal-case tracking-tight">
                          {formatDayLabel(dayKey)}
                        </time>
                        <span class="text-[10px] font-pixel text-black/20 uppercase tracking-widest">
                          {dayItems.length} {dayItems.length === 1 ? "article" : "articles"}
                        </span>
                      </div>

                      <!-- Articles list -->
                      <div class="divide-y divide-black/5">
                        {dayItems.map((item, i) => (
                          <article class="article-row px-8 py-6 transition-all duration-300 group/article">
                            <a href={item.link} target="_blank" rel="noopener noreferrer" class="block">
                              <div class="flex items-start gap-4">
                                <span class="text-[10px] font-pixel text-black/15 uppercase tracking-widest mt-1.5 shrink-0 w-5 text-right">{String(i + 1).padStart(2, "0")}</span>
                                <div class="flex-1 min-w-0">
                                  <h3 class="font-sans text-base font-semibold text-black/80 group-hover/article:text-black leading-snug mb-2 transition-colors duration-200">
                                    {item.title}
                                  </h3>
                                  {item.description && (
                                    <p class="font-sans text-xs text-black/40 leading-relaxed line-clamp-2">
                                      {item.description}
                                    </p>
                                  )}
                                </div>
                                <div class="shrink-0 mt-1 text-black/15 group-hover/article:text-black/50 transition-colors duration-200">
                                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10"/>
                                  </svg>
                                </div>
                              </div>
                            </a>
                          </article>
                        ))}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="mt-24 pt-12 border-t border-white/5 flex justify-between items-center text-white/15 text-xs font-sans">
      <span>&copy; {new Date().getFullYear()} Philapps Garage</span>
      <a href="https://github.com/openclaw/openclaw" target="_blank" rel="noopener noreferrer" class="font-pixel uppercase tracking-widest hover:text-white/40 transition-colors">Powered by 🦞 OpenClaw</a>
    </footer>
  </main>
</body>
</html>

<style>
  /* Scan progress bar */
  @keyframes scanProgress {
    0%   { width: 0%;   opacity: 0.3; }
    60%  { width: 100%; opacity: 1; }
    100% { width: 100%; opacity: 0.3; }
  }

  /* ── Animated Eye ── */
  .eye-wrapper {
    flex-shrink: 0;
  }

  .eye-svg {
    width: 1em;
    height: 1em;
    font-size: clamp(2.5rem, 6vw, 3.75rem); /* matches h1 */
    display: block;
    overflow: hidden;
  }

  /* Pupil group scans left → center → right → center */
  @keyframes eyeScan {
    0%   { transform: translateX(-10px); }
    20%  { transform: translateX(-10px); }
    40%  { transform: translateX(0px);   }
    60%  { transform: translateX(10px);  }
    80%  { transform: translateX(0px);   }
    100% { transform: translateX(-10px); }
  }

  .eye-svg .pupil-group {
    animation: eyeScan 3.6s cubic-bezier(0.45, 0, 0.55, 1) infinite;
    transform-origin: 50px 50px;
  }

  /* Reveal animation */
  .reveal-item {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Day card hover — green glow lift */
  .day-card {
    box-shadow: 0 0 0 1px rgba(255,255,255,0.06);
    will-change: transform, box-shadow;
  }

  .timeline-day:hover .day-card {
    transform: translateY(-3px);
    box-shadow:
      0 0 0 1px rgba(0, 255, 0, 0.25),
      0 8px 32px rgba(0, 255, 0, 0.06),
      0 2px 8px rgba(0, 0, 0, 0.4);
  }

  /* Timeline dot glow on hover */
  .timeline-day:hover .timeline-dot {
    border-color: rgba(0, 255, 0, 0.5);
    box-shadow: 0 0 12px rgba(0, 255, 0, 0.25);
  }

  .timeline-day:hover .inner-dot {
    background-color: #00ff00;
    box-shadow: 0 0 6px #00ff00;
  }

  /* Article row hover */
  .article-row:hover {
    background-color: rgba(0, 0, 0, 0.02);
  }

  /* Hero card CRT scanline */
  .hero-card {
    position: relative;
    overflow: hidden;
  }

  .hero-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(rgba(18,16,16,0) 50%, rgba(0,0,0,0.015) 50%);
    background-size: 100% 3px;
    pointer-events: none;
    z-index: 1;
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const siblings = [...document.querySelectorAll('.reveal-item:not(.visible)')];
          const visible = siblings.filter(el => {
            const r = el.getBoundingClientRect();
            return r.top < window.innerHeight && r.bottom > 0;
          });
          visible.forEach((el, i) => {
            setTimeout(() => el.classList.add('visible'), i * 60);
          });
        }
      });
    },
    { rootMargin: '0px 0px -60px 0px', threshold: 0.05 }
  );

  document.querySelectorAll('.reveal-item').forEach(el => observer.observe(el));
</script>
